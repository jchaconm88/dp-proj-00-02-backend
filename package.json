{
  "name": "dp-proj-00-02-backend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "deploy": "gcloud run deploy dp-proj-00-02-backend --source . --region us-central1 --allow-unauthenticated",
    "deploy:logs": "gcloud run services logs read dp-proj-00-02-backend --region us-central1 --limit 50"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.21.1",
    "firebase-admin": "^13.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
