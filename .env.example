# ============================================================
# dp-proj-00-02-backend — Variables de entorno
# ============================================================
# Copia este archivo a .env y rellena con los valores reales.
# Los project_id de ambiente los genera Terraform (dp-proj-00-02-infra).
# ============================================================

PORT=8080

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Firebase (proyecto unificado por ambiente) ───────────────
# `FIREBASE_PROJECT_ID` debe ser el `project_id` del stack Terraform (dev/qa/prd).
# Si usas `FIREBASE_SERVICE_ACCOUNT_JSON` o `FIREBASE_SERVICE_ACCOUNT_PATH`,
# el `project_id` puede venir del JSON y `FIREBASE_PROJECT_ID` es opcional.
FIREBASE_PROJECT_ID=

# Opción A: credenciales por archivo JSON (recomendado para dev local)
# FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\service-account.json

# Opción B: credenciales por JSON inline (útil en CI)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Debug ────────────────────────────────────────────────────
# ADMIN_AUTH_DISABLED=true
# AUTH_DEBUG=1
# WEB_API_DEBUG=1

# ── Cloud Run (solo referencia) ─────────────────────────────
# GCP_PROJECT_ID=<mismo project_id del ambiente>
# GCP_REGION=us-central1
# CLOUD_RUN_SERVICE_NAME=dp-proj-00-02-backend
