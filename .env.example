# ============================================================
# dp-proj-00-02-backend — Variables de entorno
# ============================================================
# Copia este archivo a .env y rellena con los valores reales.
# Los project_id de ambiente los genera Terraform (dp-proj-00-02-infra).
# ============================================================

PORT=8080

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Firebase Admin (mismo proyecto por ambiente unificado) ───
# En Cloud Run con modelo unificado, ADMIN_* y WEB_* suelen ser el mismo project_id.
ADMIN_FIREBASE_PROJECT_ID=

# ADMIN_FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\sa.json
# ADMIN_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Firebase Web / datos app (mismo proyecto en modelo unificado) ─
WEB_FIREBASE_PROJECT_ID=

# WEB_FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\sa.json
# WEB_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Debug ────────────────────────────────────────────────────
# ADMIN_AUTH_DISABLED=true
# AUTH_DEBUG=1
# WEB_API_DEBUG=1

# ── Cloud Run (scripts / documentación) ─────────────────────
# GCP_PROJECT_ID=<mismo project_id del ambiente>
# GCP_REGION=us-central1
# GCP_SERVICE_NAME=dp-proj-00-02-backend
