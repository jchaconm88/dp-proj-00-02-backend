# ============================================================
# dp-proj-00-02-backend — Variables de entorno
# ============================================================
# Copia este archivo a .env y rellena con los valores reales.
# En Cloud Run, configura estas variables en la consola de GCP
# o via `gcloud run deploy --set-env-vars ...`
# ============================================================

# Puerto (Cloud Run lo inyecta automáticamente; local usa 8080)
PORT=8080

# ── CORS ─────────────────────────────────────────────────────
# Lista separada por comas de orígenes permitidos.
# Incluye todos los dominios de tus frontends (admin, web, landing).
# NO uses "*" si necesitas credentials (cookies/auth headers).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Firebase Admin Auth (Proyecto Admin) ─────────────────────
# El proyecto de Firebase donde viven los usuarios del panel Admin.
# Necesario para que verifyIdToken() acepte tokens de ese proyecto.
ADMIN_FIREBASE_PROJECT_ID=dp-proj-00-02-admin-q

# (Opcional) Ruta a un Service Account JSON del proyecto Admin (recomendado en dev local).
# Evita depender de ADC/gcloud y errores como invalid_rapt.
# ADMIN_FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\admin-sa.json
#
# (Opcional) Alternativa: JSON completo del Service Account (menos recomendado por tamaño/escapes).
# ADMIN_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Firebase Web Data (Proyecto Web) ─────────────────────────
# El proyecto de Firebase donde viven los datos de la app Web
# (Firestore, Auth de clientes, etc).
WEB_FIREBASE_PROJECT_ID=

# (Opcional) Ruta a un Service Account JSON del proyecto Web.
# WEB_FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\web-sa.json
#
# (Opcional) Alternativa: JSON completo del Service Account del proyecto Web.
# Necesario si el backend necesita leer/escribir Firestore del
# proyecto Web desde un proyecto GCP distinto.
# WEB_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Debug ────────────────────────────────────────────────────
# Desactivar auth para pruebas locales rápidas (NO usar en prod)
# ADMIN_AUTH_DISABLED=true

# Incluir mensaje de error detallado en 401 (solo staging/dev)
# AUTH_DEBUG=1

# Logs detallados de rutas /web (membresía, conteos). NO usar en prod ruidosa.
# WEB_API_DEBUG=1

# ── Cloud Run Deploy ─────────────────────────────────────────
# Estas variables se usan en los scripts de deploy (no en runtime)
# GCP_PROJECT=dp-proj-00-02-backend-q
# GCP_REGION=us-central1
# GCP_SERVICE_NAME=dp-proj-00-02-backend
